# Auto detect text files and perform LF normalization
* text=auto

# Force LF line endings for these file types
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Linguist language overrides for better stats
*.js linguist-language=JavaScript
*.md linguist-language=Markdown
